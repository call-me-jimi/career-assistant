# Copy this file to `.env` and fill in your own values.
# API keys are read ONLY from .env — they are never written to settings.json.

# --- LLM provider (required) ---------------------------------------------
# provider: anthropic | openai | ollama | http
LLM_PROVIDER=anthropic
LLM_MODEL_NAME=claude-sonnet-4-5
# Generic key used as a fallback for whichever provider is active.
LLM_API_KEY=sk-...

# Provider-specific keys (optional; override LLM_API_KEY for that provider)
ANTHROPIC_API_KEY=
OPENAI_API_KEY=
# For Ollama (no key needed) or a generic HTTP endpoint:
OLLAMA_BASE_URL=http://localhost:11434
LLM_BASE_URL=

# --- Optional integrations ------------------------------------------------
# Web-augmented company/salary research (https://tavily.com). Omitted = skipped.
TAVILY_API_KEY=

# Google Sheets export (see docs/SETUP.md). Omitted = Sheets export disabled.
GOOGLE_SHEETS_SPREADSHEET_ID=
GOOGLE_SHEETS_CREDENTIALS_PATH=/absolute/path/to/service_account.json

# HuggingFace token — only needed if the chosen Whisper model is gated.
HF_TOKEN=

# OpenTelemetry collector (e.g. Arize Phoenix). Omitted = in-process tracing only.
PHOENIX_COLLECTOR_ENDPOINT=

# --- Output / runtime -----------------------------------------------------
# Where exported PDFs / Markdown / JSON are written.
DEFAULT_EXPORT_FOLDER=~/JobApplications/Applications
# DEBUG for verbose request + LLM logging.
JOB_APP_LOG_LEVEL=INFO
